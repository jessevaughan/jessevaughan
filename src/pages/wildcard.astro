<script>
// ═══════════════════════════════════════════════════════
//  WINDOW MANAGER
// ═══════════════════════════════════════════════════════
let zTop = 100;
const minimized = {};

// App registry — add new apps here
const APPS = {
  wa:  { icon: '🎵', label: 'Winamp'      },
  mtg: { icon: '🃏', label: 'MTG'         },
  ms:  { icon: '💣', label: 'Minesweeper' },
  aim: { icon: '💬', label: 'AIM'         },
  d2:  { icon: '⚔️',  label: 'Diablo II'  },
  fl:  { icon: '🎹', label: 'FruityLoops' },
};

function openApp(id) {
  const el = document.getElementById('app-' + id);
  if (!el) return;
  el.style.display = 'block';
  delete minimized['app-' + id];
  focus(el);
  rebuildTaskbar();
  // Init on first open
  if (!el.dataset.ready) {
    el.dataset.ready = '1';
    if (id === 'wa')  initWinamp();
    if (id === 'ms')  initMinesweeper();
    if (id === 'fl')  initFL();
    if (id === 'mtg') drawMtgCard();
  }
}

function closeApp(id) {
  const el = document.getElementById(id);
  if (!el) return;
  el.style.display = 'none';
  delete minimized[id];
  rebuildTaskbar();
}

function minimizeApp(id) {
  const el = document.getElementById(id);
  if (!el) return;
  el.style.display = 'none';
  minimized[id] = true;
  rebuildTaskbar();
}

function focus(el) {
  document.querySelectorAll('.xp-win, #err-popup').forEach(w => {
    w.querySelector('.title-bar')?.classList.add('inactive');
  });
  el.querySelector('.title-bar')?.classList.remove('inactive');
  el.style.zIndex = ++zTop;
}

function rebuildTaskbar() {
  const bar = document.getElementById('tb-apps');
  bar.innerHTML = '';
  Object.entries(APPS).forEach(([id, meta]) => {
    const el = document.getElementById('app-' + id);
    const visible = el && el.style.display !== 'none';
    const isMin   = minimized['app-' + id];
    if (!visible && !isMin) return;
    const btn = document.createElement('button');
    btn.className = 'tb-btn' + (visible ? ' active' : '');
    btn.textContent = meta.icon + ' ' + meta.label;
    btn.onclick = () => {
      if (!visible || isMin) openApp(id);
      else minimizeApp('app-' + id);
    };
    bar.appendChild(btn);
  });
}

// Focus window on click anywhere on it
document.querySelectorAll('.xp-win').forEach(el => {
  el.addEventListener('mousedown', () => { focus(el); rebuildTaskbar(); });
});
document.getElementById('desktop').addEventListener('click', closeStartMenu);

// ── DRAG ──
let drag = null;

function dragStart(e, id) {
  if (e.target.tagName === 'BUTTON') return; // don't drag when clicking controls
  const el = document.getElementById(id);
  focus(el); rebuildTaskbar();
  const r = el.getBoundingClientRect();
  drag = { id, ox: r.left, oy: r.top, sx: e.clientX, sy: e.clientY };
  e.preventDefault();
}

document.addEventListener('mousemove', e => {
  if (!drag) return;
  const el = document.getElementById(drag.id);
  el.style.left = (drag.ox + e.clientX - drag.sx) + 'px';
  el.style.top  = (drag.oy + e.clientY - drag.sy) + 'px';
});
document.addEventListener('mouseup', () => drag = null);


// ═══════════════════════════════════════════════════════
//  CLOCK + AIM TIMER
// ═══════════════════════════════════════════════════════
let aimSeconds = 0;
setInterval(() => {
  const now = new Date();
  let h = now.getHours(), m = String(now.getMinutes()).padStart(2, '0');
  const ap = h >= 12 ? 'PM' : 'AM'; h = h % 12 || 12;
  document.getElementById('clock').textContent = `${h}:${m} ${ap}`;

  aimSeconds++;
  const ah = Math.floor(aimSeconds / 3600);
  const am = Math.floor((aimSeconds % 3600) / 60);
  const as = aimSeconds % 60;
  const t = document.getElementById('aim-timer');
  if (t) t.textContent = `${ah}:${String(am).padStart(2,'0')}:${String(as).padStart(2,'0')}`;
}, 1000);


// ═══════════════════════════════════════════════════════
//  START MENU
// ═══════════════════════════════════════════════════════
function toggleStartMenu(e) { e.stopPropagation(); document.getElementById('smenu').classList.toggle('open'); }
function closeStartMenu() { document.getElementById('smenu').classList.remove('open'); }


// ═══════════════════════════════════════════════════════
//  ERROR POPUPS
// ═══════════════════════════════════════════════════════
// ✏️ CUSTOMIZE: add/change error messages
const ERRORS = [
  "FATAL ERROR: Too many sick beats.\nSystem overwhelmed.",
  "WARNING: MTG collection exceeds recommended limits.\nPlease acquire more shelf space.",
  "ERROR: Diablo II ran out of mana.\nPlease insert more coffee.",
  "CRITICAL: Design system approaching perfection.\nEmergency reboot required.",
  "ERROR 404: Sleep not found.\nResuming work.",
  "FruityLoops 3.4 has performed an illegal\noperation and will be shut down.",
  "WARNING: Joshua Tree vibes critically high.\nDesktop temperature threshold exceeded.",
  "Kazaa download complete:\n'Eminem - Without Me.mp3' (3.4MB, 128kbps)",
];
let errIdx = 0;

function showError() {
  const p = document.getElementById('err-popup');
  document.getElementById('err-msg').textContent = ERRORS[errIdx++ % ERRORS.length];
  p.style.left = (80  + Math.random() * 500) + 'px';
  p.style.top  = (60  + Math.random() * 280) + 'px';
  p.style.zIndex = ++zTop;
  p.classList.add('show');
}
function closeError() { document.getElementById('err-popup').classList.remove('show'); }
// Occasional random error
setInterval(() => { if (Math.random() < 0.12) showError(); }, 50000);


// ═══════════════════════════════════════════════════════
//  WINAMP
// ═══════════════════════════════════════════════════════
// ✏️ CUSTOMIZE: swap out track names with anything you want
const TRACKS = [
  'Boards of Canada - Aquarius',
  'Daft Punk - Digital Love',
  'Aphex Twin - Xtal',
  'Portishead - Sour Times',
  'Massive Attack - Teardrop',
  'Chemical Brothers - Block Rockin Beats',
  'Prodigy - Firestarter',
  'Radiohead - Everything In Its Right Place',
];

let waTrack = 0, waSeconds = 134, waPlaying = true;

function initWinamp() {
  // Build visualizer bars
  const viz = document.getElementById('wa-viz');
  for (let i = 0; i < 24; i++) {
    const b = document.createElement('div');
    b.className = 'wa-bar';
    b.style.setProperty('--lo', (Math.random() * 4 + 2) + 'px');
    b.style.setProperty('--hi', (Math.random() * 14 + 4) + 'px');
    b.style.animationDelay    = (Math.random() * 0.5) + 's';
    b.style.animationDuration = (0.06 + Math.random() * 0.14) + 's';
    viz.appendChild(b);
  }

  // Build playlist
  const list = document.getElementById('wa-list');
  TRACKS.forEach((name, i) => {
    const li = document.createElement('div');
    li.className = 'wa-li' + (i === 0 ? ' now' : '');
    li.dataset.i = i;
    li.innerHTML = `<span class="wa-num">${String(i+1).padStart(2,'0')}</span>${name}`;
    li.addEventListener('click', () => { waTrack = i; waSeconds = 0; waPlaying = true; updateWinamp(); document.getElementById('wa-pb').textContent='▐▐'; });
    list.appendChild(li);
  });

  // Tick timer
  setInterval(() => {
    if (!waPlaying) return;
    waSeconds++;
    const m = Math.floor(waSeconds / 60), s = String(waSeconds % 60).padStart(2,'0');
    const el = document.getElementById('wa-time'); if (el) el.textContent = `${m}:${s}`;
    if (waSeconds > 240) { waSeconds = 0; waTrack = (waTrack + 1) % TRACKS.length; updateWinamp(); }
  }, 1000);
}

function updateWinamp() {
  const el = document.getElementById('wa-track'); if (el) el.textContent = '▶ ' + TRACKS[waTrack];
  document.querySelectorAll('.wa-li').forEach(li => li.classList.toggle('now', parseInt(li.dataset.i) === waTrack));
}
function waToggle() { waPlaying = !waPlaying; const pb = document.getElementById('wa-pb'); if (pb) pb.textContent = waPlaying ? '▐▐' : '▶'; }
function waNext()   { waTrack = (waTrack + 1) % TRACKS.length; waSeconds = 0; updateWinamp(); }
function waPrev()   { waTrack = (waTrack - 1 + TRACKS.length) % TRACKS.length; waSeconds = 0; updateWinamp(); }


// ═══════════════════════════════════════════════════════
//  MTG CARD VIEWER
// ═══════════════════════════════════════════════════════
let mtgSet = 'ice';

function setMtgSet(set, btn) {
  mtgSet = set;
  document.querySelectorAll('.mtg-set-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
}

async function drawMtgCard() {
  const card = document.getElementById('mtg-card');
  const name = document.getElementById('mtg-name');
  card.innerHTML = '<div class="mtg-loading">Shuffling library...</div>';
  name.textContent = '';
  try {
    const res  = await fetch(`https://api.scryfall.com/cards/random?q=set:${mtgSet}`);
    const data = await res.json();
    const img  = data.image_uris?.normal || data.card_faces?.[0]?.image_uris?.normal;
    if (img) {
      card.innerHTML = `<img src="${img}" alt="${data.name}">`;
      name.textContent = data.name;
    } else {
      card.innerHTML = `<div class="mtg-loading">${data.name}<br><em>${data.type_line || ''}</em></div>`;
    }
  } catch {
    card.innerHTML = '<div class="mtg-loading">Spell fizzled.<br>Try again.</div>';
  }
}


// ═══════════════════════════════════════════════════════
//  MINESWEEPER
// ═══════════════════════════════════════════════════════
const ROWS = 9, COLS = 9, MINE_COUNT = 10;
let board = [], gameOver = false, firstClick = true, msTime = 0, msInterval = null, flagCount = MINE_COUNT;

function initMinesweeper() {
  board = []; gameOver = false; firstClick = true; msTime = 0; flagCount = MINE_COUNT;
  clearInterval(msInterval);
  for (let r = 0; r < ROWS; r++) { board[r] = []; for (let c = 0; c < COLS; c++) board[r][c] = {mine:false,open:false,flag:false,adj:0}; }
  renderMinesweeper();
}

function placeMines(avoidR, avoidC) {
  let placed = 0;
  while (placed < MINE_COUNT) {
    const r = Math.floor(Math.random() * ROWS), c = Math.floor(Math.random() * COLS);
    if (!board[r][c].mine && !(r === avoidR && c === avoidC)) { board[r][c].mine = true; placed++; }
  }
  for (let r = 0; r < ROWS; r++) for (let c = 0; c < COLS; c++) {
    if (board[r][c].mine) continue;
    let n = 0;
    for (let dr = -1; dr <= 1; dr++) for (let dc = -1; dc <= 1; dc++) {
      const nr = r+dr, nc = c+dc;
      if (nr >= 0 && nr < ROWS && nc >= 0 && nc < COLS && board[nr][nc].mine) n++;
    }
    board[r][c].adj = n;
  }
}

function renderMinesweeper() {
  document.getElementById('ms-body').innerHTML = `
    <div class="ms-head">
      <div class="ms-count" id="ms-flags">${String(flagCount).padStart(3,'0')}</div>
      <div class="ms-face" id="ms-face" onclick="initMinesweeper()">🙂</div>
      <div class="ms-count" id="ms-time">000</div>
    </div>
    <div class="ms-grid" id="ms-grid" style="grid-template-columns:repeat(${COLS},22px)"></div>`;
  const grid = document.getElementById('ms-grid');
  for (let r = 0; r < ROWS; r++) for (let c = 0; c < COLS; c++) {
    const cell = document.createElement('div');
    cell.className = 'ms-cell'; cell.dataset.r = r; cell.dataset.c = c;
    cell.addEventListener('click', () => msOpen(r, c));
    cell.addEventListener('contextmenu', e => { e.preventDefault(); msFlag(r, c); });
    grid.appendChild(cell);
  }
}

function msOpen(r, c) {
  if (gameOver || board[r][c].open || board[r][c].flag) return;
  if (firstClick) {
    firstClick = false; placeMines(r, c);
    msInterval = setInterval(() => { msTime++; const el = document.getElementById('ms-time'); if (el) el.textContent = String(Math.min(msTime, 999)).padStart(3,'0'); }, 1000);
  }
  board[r][c].open = true;
  if (board[r][c].mine) {
    gameOver = true; clearInterval(msInterval);
    const face = document.getElementById('ms-face'); if (face) face.textContent = '😵';
    for (let rr=0;rr<ROWS;rr++) for (let cc=0;cc<COLS;cc++) if (board[rr][cc].mine) board[rr][cc].open = true;
  } else if (board[r][c].adj === 0) {
    for (let dr=-1;dr<=1;dr++) for (let dc=-1;dc<=1;dc++) {
      const nr=r+dr, nc=c+dc;
      if (nr>=0&&nr<ROWS&&nc>=0&&nc<COLS) msOpen(nr, nc);
    }
  }
  renderMsGrid();
  if (!gameOver) {
    let remaining = 0;
    for (let rr=0;rr<ROWS;rr++) for (let cc=0;cc<COLS;cc++) if (!board[rr][cc].mine && !board[rr][cc].open) remaining++;
    if (remaining === 0) { gameOver=true; clearInterval(msInterval); const face=document.getElementById('ms-face'); if(face)face.textContent='😎'; }
  }
}

function msFlag(r, c) {
  if (gameOver || board[r][c].open) return;
  board[r][c].flag = !board[r][c].flag;
  flagCount += board[r][c].flag ? -1 : 1;
  const el = document.getElementById('ms-flags'); if (el) el.textContent = String(flagCount).padStart(3,'0');
  renderMsGrid();
}

function renderMsGrid() {
  document.querySelectorAll('.ms-cell').forEach(el => {
    const r = parseInt(el.dataset.r), c = parseInt(el.dataset.c), cell = board[r][c];
    el.className = 'ms-cell'; el.textContent = '';
    if (cell.flag && !cell.open) { el.textContent = '🚩'; }
    else if (cell.open) {
      el.classList.add('open');
      if (cell.mine) { el.classList.add('dead'); el.textContent = '💣'; }
      else if (cell.adj > 0) { el.textContent = cell.adj; el.classList.add('n' + cell.adj); }
    }
  });
}


// ═══════════════════════════════════════════════════════
//  FRUITYLOOPS
// ═══════════════════════════════════════════════════════
// ✏️ CUSTOMIZE: track names and initial pattern
const FL_TRACKS = [
  { name: 'Kick',   cls: 'kick'  },
  { name: 'Snare',  cls: 'snare' },
  { name: 'Hi-Hat', cls: 'hihat' },
  { name: 'Bass',   cls: 'bass'  },
];
const FL_STEPS = 16;
let flPads = [], flStep = -1, flPlaying = false, flBPM = 120, flTimer = null, audioCtx = null;

function initFL() {
  flPads = FL_TRACKS.map(() => Array(FL_STEPS).fill(false));
  // Default pattern — edit these arrays to change the beat
  [0,4,8,12].forEach(s => flPads[0][s] = true);  // Kick
  [4,12].forEach(s => flPads[1][s] = true);        // Snare
  [2,6,10,14].forEach(s => flPads[2][s] = true);   // Hi-hat
  [0,6,10].forEach(s => flPads[3][s] = true);      // Bass
  renderFL();
}

function renderFL() {
  let html = `
    <div class="fl-toolbar">
      <button class="fl-btn" id="fl-play" onclick="flToggle()">▶ Play</button>
      <button class="fl-btn" onclick="flStop()">■ Stop</button>
      <button class="fl-btn" onclick="flClear()">✕ Clear</button>
      <span class="fl-bpm-label">BPM: <strong class="fl-bpm-val" id="fl-bpm">${flBPM}</strong></span>
      <input type="range" min="60" max="200" value="${flBPM}" style="width:55px;cursor:pointer"
        oninput="flSetBPM(this.value)">
    </div>
    <div class="fl-nums">
      <div></div>
      ${Array.from({length:FL_STEPS},(_,i) => `<div class="fl-num${i%4===0?' beat':''}">${i+1}</div>`).join('')}
    </div>`;
  FL_TRACKS.forEach((t, ti) => {
    html += `<div class="fl-row">
      <div class="fl-label">${t.name}</div>
      ${Array.from({length:FL_STEPS},(_,si) =>
        `<div class="fl-pad ${t.cls}${flPads[ti][si]?' on':''}" id="flp${ti}_${si}"
              onclick="flTogglePad(${ti},${si})"></div>`).join('')}
    </div>`;
  });
  document.getElementById('fl-body').innerHTML = html;
}

function flTogglePad(ti, si) {
  flPads[ti][si] = !flPads[ti][si];
  const el = document.getElementById(`flp${ti}_${si}`);
  if (el) el.classList.toggle('on', flPads[ti][si]);
}
function flToggle() { flPlaying ? flStop() : flPlay(); }
function flPlay() {
  flPlaying = true;
  const btn = document.getElementById('fl-play'); if (btn) { btn.textContent = '▐▐ Pause'; btn.classList.add('playing'); }
  if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
  flStep = 0;
  flTimer = setInterval(() => { flTick(); flStep = (flStep + 1) % FL_STEPS; }, (60 / flBPM / 4) * 1000);
}
function flStop() {
  flPlaying = false; clearInterval(flTimer); flStep = -1;
  const btn = document.getElementById('fl-play'); if (btn) { btn.textContent = '▶ Play'; btn.classList.remove('playing'); }
  document.querySelectorAll('.fl-pad.step').forEach(p => p.classList.remove('step'));
}
function flClear() { flStop(); flPads = FL_TRACKS.map(() => Array(FL_STEPS).fill(false)); renderFL(); }
function flSetBPM(v) {
  flBPM = parseInt(v);
  const el = document.getElementById('fl-bpm'); if (el) el.textContent = flBPM;
  if (flPlaying) { flStop(); flPlay(); }
}
function flTick() {
  const s = flStep;
  document.querySelectorAll('.fl-pad').forEach(p => p.classList.remove('step'));
  FL_TRACKS.forEach((_, ti) => {
    const el = document.getElementById(`flp${ti}_${s}`); if (el) el.classList.add('step');
    if (flPads[ti][s]) flDrum(ti);
  });
}
function flDrum(ti) {
  if (!audioCtx) return;
  const t = audioCtx.currentTime;
  if (ti === 0) { // Kick
    const o = audioCtx.createOscillator(), g = audioCtx.createGain();
    o.connect(g); g.connect(audioCtx.destination);
    o.frequency.setValueAtTime(150, t); o.frequency.exponentialRampToValueAtTime(30, t+0.15);
    g.gain.setValueAtTime(1, t); g.gain.exponentialRampToValueAtTime(0.001, t+0.3);
    o.start(t); o.stop(t+0.3);
  } else if (ti === 1) { // Snare
    const buf = audioCtx.createBuffer(1, audioCtx.sampleRate*0.15, audioCtx.sampleRate);
    const d = buf.getChannelData(0); for (let i=0;i<d.length;i++) d[i]=Math.random()*2-1;
    const src = audioCtx.createBufferSource(), g = audioCtx.createGain();
    g.gain.setValueAtTime(0.5,t); g.gain.exponentialRampToValueAtTime(0.001,t+0.15);
    src.buffer=buf; src.connect(g); g.connect(audioCtx.destination); src.start(t);
  } else if (ti === 2) { // Hi-hat
    const buf = audioCtx.createBuffer(1, audioCtx.sampleRate*0.04, audioCtx.sampleRate);
    const d = buf.getChannelData(0); for (let i=0;i<d.length;i++) d[i]=Math.random()*2-1;
    const src = audioCtx.createBufferSource(), f = audioCtx.createBiquadFilter(), g = audioCtx.createGain();
    f.type='highpass'; f.frequency.value=8000;
    g.gain.setValueAtTime(0.25,t); g.gain.exponentialRampToValueAtTime(0.001,t+0.04);
    src.connect(f); f.connect(g); g.connect(audioCtx.destination); src.start(t);
  } else { // Bass
    const o = audioCtx.createOscillator(), g = audioCtx.createGain();
    o.type='sine'; o.frequency.value=80;
    g.gain.setValueAtTime(0.6,t); g.gain.exponentialRampToValueAtTime(0.001,t+0.25);
    o.connect(g); g.connect(audioCtx.destination); o.start(t); o.stop(t+0.25);
  }
}


