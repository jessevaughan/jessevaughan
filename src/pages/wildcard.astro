<script>
// ═══════════════════════════════════════
// WINDOW MANAGER
// ═══════════════════════════════════════
let zTop = 100;
const minimized = {};

const winMeta = {
  winamp:      { icon: '🎵', label: 'Winamp' },
  mtg:         { icon: '🃏', label: 'MTG' },
  minesweeper: { icon: '💣', label: 'Minesweeper' },
  aim:         { icon: '💬', label: 'AIM' },
  diablo:      { icon: '⚔️', label: 'Diablo II' },
  fl:          { icon: '🎹', label: 'FruityLoops' },
};

function openWindow(id) {
  const win = document.getElementById('win-' + id);
  if (!win) return;
  win.style.display = 'flex';
  win.style.flexDirection = 'column';
  delete minimized['win-' + id];
  focusWin(win);
  updateTaskbar();
  if (!win.dataset.init) {
    win.dataset.init = '1';
    if (id === 'minesweeper') initMinesweeper();
    if (id === 'fl') initFL();
    if (id === 'mtg') drawMtgCard();
    if (id === 'winamp') initWinamp();
  }
}

function closeWindow(winId) {
  const win = document.getElementById(winId);
  if (win) { win.style.display = 'none'; delete minimized[winId]; updateTaskbar(); }
}

function minimizeWindow(winId) {
  const win = document.getElementById(winId);
  if (win) { win.style.display = 'none'; minimized[winId] = true; updateTaskbar(); }
}

function focusWin(win) {
  document.querySelectorAll('.window').forEach(w => w.classList.add('inactive'));
  win.classList.remove('inactive');
  zTop++;
  win.style.zIndex = zTop;
}

function updateTaskbar() {
  const bar = document.getElementById('taskbar-apps');
  bar.innerHTML = '';
  Object.entries(winMeta).forEach(([id, meta]) => {
    const winId = 'win-' + id;
    const win = document.getElementById(winId);
    const visible = win && win.style.display !== 'none';
    const isMin = minimized[winId];
    if (!visible && !isMin) return;
    const btn = document.createElement('div');
    btn.className = 'taskbar-app' + (visible ? ' focused' : '');
    btn.innerHTML = `${meta.icon} ${meta.label}`;
    btn.onclick = () => {
      if (isMin || !visible) {
        openWindow(id);
      } else {
        minimizeWindow(winId);
      }
    };
    bar.appendChild(btn);
  });
}

// ── DRAGGING ──
let drag = null;

function startDrag(e, winId) {
  const win = document.getElementById(winId);
  focusWin(win); updateTaskbar();
  drag = {
    winId,
    sx: e.clientX, sy: e.clientY,
    ox: parseInt(win.style.left) || win.offsetLeft,
    oy: parseInt(win.style.top) || win.offsetTop,
  };
  e.preventDefault();
}

document.addEventListener('mousemove', e => {
  if (!drag) return;
  const win = document.getElementById(drag.winId);
  win.style.left = (drag.ox + e.clientX - drag.sx) + 'px';
  win.style.top  = (drag.oy + e.clientY - drag.sy) + 'px';
});
document.addEventListener('mouseup', () => drag = null);

document.querySelectorAll('.window').forEach(win => {
  win.addEventListener('mousedown', () => { focusWin(win); updateTaskbar(); });
});
document.getElementById('desktop').addEventListener('click', closeStartMenu);

// ═══════════════════════════════════════
// CLOCK + AIM TIMER
// ═══════════════════════════════════════
let aimSeconds = 0;
function updateClock() {
  const now = new Date();
  let h = now.getHours(), m = now.getMinutes().toString().padStart(2,'0');
  const ampm = h >= 12 ? 'PM' : 'AM';
  h = h % 12 || 12;
  document.getElementById('clock').textContent = `${h}:${m} ${ampm}`;
  aimSeconds++;
  const ah = Math.floor(aimSeconds/3600), am = Math.floor((aimSeconds%3600)/60), as2 = aimSeconds%60;
  const el = document.getElementById('aim-timer');
  if (el) el.textContent = `${ah}:${String(am).padStart(2,'0')}:${String(as2).padStart(2,'0')}`;
}
updateClock();
setInterval(updateClock, 1000);

// ═══════════════════════════════════════
// START MENU
// ═══════════════════════════════════════
function toggleStartMenu() {
  document.getElementById('start-menu').classList.toggle('open');
  event.stopPropagation();
}
function closeStartMenu() { document.getElementById('start-menu').classList.remove('open'); }

// ═══════════════════════════════════════
// ERROR POPUPS
// ═══════════════════════════════════════
const errors = [
  "FATAL ERROR: Too many sick beats. System overwhelmed.",
  "WARNING: MTG card collection exceeds recommended limits.\nPlease add more shelf space.",
  "ERROR: Diablo II ran out of mana. Please insert more coffee.",
  "CRITICAL: Design system approaching perfection. Reboot required.",
  "ERROR 404: Sleep not found. Resuming work.",
  "RUNTIME ERROR: FruityLoops 3.4 has performed an illegal operation\nand will be shut down.",
  "WARNING: Joshua Tree vibes dangerously high.\nDesert temperature threshold exceeded.",
  "Kazaa download complete: 1 file (Eminem - Without Me.mp3)\nEstimated size: 3.4MB",
];
let errIdx = 0;

function triggerError() {
  const popup = document.getElementById('error-popup');
  document.getElementById('error-msg').textContent = errors[errIdx++ % errors.length];
  popup.style.left = (100 + Math.random() * 400) + 'px';
  popup.style.top  = (80  + Math.random() * 300) + 'px';
  popup.classList.add('visible');
  popup.style.zIndex = ++zTop;
}
function closeError() { document.getElementById('error-popup').classList.remove('visible'); }
setInterval(() => { if (Math.random() < 0.2) triggerError(); }, 45000);

// ═══════════════════════════════════════
// WINAMP
// ═══════════════════════════════════════
const tracks = [
  "Boards of Canada - Aquarius",
  "Daft Punk - Digital Love",
  "Aphex Twin - Xtal",
  "Portishead - Sour Times",
  "Massive Attack - Teardrop",
  "Chemical Brothers - Block Rockin Beats",
  "Prodigy - Firestarter",
];
let wTrack = 0, wSecs = 134, wPlaying = true, wTimer = null;

function initWinamp() {
  const viz = document.getElementById('winamp-viz');
  for (let i = 0; i < 22; i++) {
    const b = document.createElement('div');
    b.className = 'winamp-viz-bar';
    b.style.setProperty('--h1', (Math.random()*6+2) + 'px');
    b.style.setProperty('--h2', (Math.random()*14+4) + 'px');
    b.style.animationDelay = (Math.random()*0.4) + 's';
    b.style.animationDuration = (0.06+Math.random()*0.14) + 's';
    viz.appendChild(b);
  }
  wTimer = setInterval(() => {
    if (!wPlaying) return;
    wSecs++;
    const m = Math.floor(wSecs/60), s = String(wSecs%60).padStart(2,'0');
    const el = document.getElementById('winamp-time');
    if (el) el.textContent = `${m}:${s}`;
    if (wSecs > 240) { wSecs = 0; wTrack = (wTrack+1)%tracks.length; updateWTrack(); }
  }, 1000);
  document.querySelectorAll('.winamp-playlist-item').forEach(el => {
    el.addEventListener('click', () => {
      wTrack = parseInt(el.dataset.idx); wSecs = 0; wPlaying = true; updateWTrack();
      document.getElementById('winamp-play-btn').textContent = '⏸';
    });
  });
}
function updateWTrack() {
  const el = document.getElementById('winamp-track');
  if (el) el.textContent = '▶ ' + tracks[wTrack];
  document.querySelectorAll('.winamp-playlist-item').forEach(e => {
    e.classList.toggle('active', parseInt(e.dataset.idx) === wTrack);
  });
}
function winampPlayPause() {
  wPlaying = !wPlaying;
  document.getElementById('winamp-play-btn').textContent = wPlaying ? '⏸' : '▶';
}
function winampNext() { wTrack = (wTrack+1)%tracks.length; wSecs=0; updateWTrack(); }
function winampPrev() { wTrack = (wTrack-1+tracks.length)%tracks.length; wSecs=0; updateWTrack(); }

// ═══════════════════════════════════════
// MTG CARD VIEWER
// ═══════════════════════════════════════
let mtgSet = 'ice';
function setMtgSet(set, btn) {
  mtgSet = set;
  document.querySelectorAll('.mtg-set-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
}
async function drawMtgCard() {
  const d = document.getElementById('mtg-card-display');
  d.innerHTML = '<div class="mtg-card-loading">Shuffling library...</div>';
  try {
    const res = await fetch(`https://api.scryfall.com/cards/random?q=set:${mtgSet}`);
    const card = await res.json();
    let img = card.image_uris?.normal || card.card_faces?.[0]?.image_uris?.normal;
    d.innerHTML = img
      ? `<img src="${img}" alt="${card.name}" />`
      : `<div class="mtg-card-loading">${card.name}<br/><em>${card.type_line||''}</em></div>`;
  } catch {
    d.innerHTML = '<div class="mtg-card-loading">Spell fizzled.<br/>Try again.</div>';
  }
}

// ═══════════════════════════════════════
// MINESWEEPER
// ═══════════════════════════════════════
const R=9, C=9, MINES=10;
let board=[], gameOver=false, firstClick=true, msTimer=0, msTimerInt=null;

function initMinesweeper() {
  board=[]; gameOver=false; firstClick=true; msTimer=0;
  clearInterval(msTimerInt);
  for (let r=0;r<R;r++) {
    board[r]=[];
    for (let c=0;c<C;c++) board[r][c]={mine:false,revealed:false,flagged:false,adj:0};
  }
  renderMS();
}

function placeMines(ar,ac) {
  let p=0;
  while(p<MINES){
    const r=Math.floor(Math.random()*R), c=Math.floor(Math.random()*C);
    if (!board[r][c].mine && !(r===ar&&c===ac)) { board[r][c].mine=true; p++; }
  }
  for(let r=0;r<R;r++) for(let c=0;c<C;c++) {
    if(board[r][c].mine) continue;
    let n=0;
    for(let dr=-1;dr<=1;dr++) for(let dc=-1;dc<=1;dc++) {
      const nr=r+dr,nc=c+dc;
      if(nr>=0&&nr<R&&nc>=0&&nc<C&&board[nr][nc].mine) n++;
    }
    board[r][c].adj=n;
  }
}

function renderMS() {
  const cont = document.getElementById('ms-container');
  cont.innerHTML = `
    <div class="ms-header">
      <div class="ms-counter" id="ms-mines">${String(MINES).padStart(3,'0')}</div>
      <div class="ms-face-btn" id="ms-face" onclick="initMinesweeper()">🙂</div>
      <div class="ms-counter" id="ms-timer">000</div>
    </div>
    <div class="ms-grid" id="ms-grid" style="grid-template-columns:repeat(${C},22px)"></div>`;
  const grid=document.getElementById('ms-grid');
  for(let r=0;r<R;r++) for(let c=0;c<C;c++) {
    const cell=document.createElement('div');
    cell.className='ms-cell'; cell.dataset.r=r; cell.dataset.c=c;
    cell.addEventListener('click',()=>msReveal(r,c));
    cell.addEventListener('contextmenu',e=>{e.preventDefault();msFlag(r,c);});
    grid.appendChild(cell);
  }
}

function msReveal(r,c) {
  if(gameOver||board[r][c].revealed||board[r][c].flagged) return;
  if(firstClick) {
    firstClick=false; placeMines(r,c);
    msTimerInt=setInterval(()=>{ msTimer++;
      const el=document.getElementById('ms-timer');
      if(el) el.textContent=String(Math.min(msTimer,999)).padStart(3,'0');
    },1000);
  }
  board[r][c].revealed=true;
  if(board[r][c].mine) {
    gameOver=true; clearInterval(msTimerInt);
    document.getElementById('ms-face').textContent='😵';
    for(let rr=0;rr<R;rr++) for(let cc=0;cc<C;cc++) if(board[rr][cc].mine) board[rr][cc].revealed=true;
  } else if(board[r][c].adj===0) {
    for(let dr=-1;dr<=1;dr++) for(let dc=-1;dc<=1;dc++) {
      const nr=r+dr,nc=c+dc;
      if(nr>=0&&nr<R&&nc>=0&&nc<C) msReveal(nr,nc);
    }
  }
  updateMSGrid();
  if(!gameOver){
    let unsafe=0;
    for(let rr=0;rr<R;rr++) for(let cc=0;cc<C;cc++) if(!board[rr][cc].mine&&!board[rr][cc].revealed) unsafe++;
    if(unsafe===0){ gameOver=true; clearInterval(msTimerInt); document.getElementById('ms-face').textContent='😎'; }
  }
}

function msFlag(r,c) {
  if(gameOver||board[r][c].revealed) return;
  board[r][c].flagged=!board[r][c].flagged;
  const el=document.getElementById('ms-mines');
  const cur=parseInt(el.textContent);
  el.textContent=String(cur+(board[r][c].flagged?-1:1)).padStart(3,'0');
  updateMSGrid();
}

function updateMSGrid() {
  document.querySelectorAll('.ms-cell').forEach(el=>{
    const r=parseInt(el.dataset.r), c=parseInt(el.dataset.c), cell=board[r][c];
    el.className='ms-cell'; el.textContent='';
    if(cell.flagged&&!cell.revealed) { el.textContent='🚩'; }
    else if(cell.revealed) {
      el.classList.add('revealed');
      if(cell.mine) { el.classList.add('mine'); el.textContent='💣'; }
      else if(cell.adj>0) { el.textContent=cell.adj; el.classList.add(`ms-num-${cell.adj}`); }
    }
  });
}

// ═══════════════════════════════════════
// FRUITYLOOPS
// ═══════════════════════════════════════
const FL_TRACKS=[
  {name:'Kick', cls:'kick'},
  {name:'Snare',cls:'snare'},
  {name:'Hi-Hat',cls:'hihat'},
  {name:'Bass', cls:'bass'},
];
const STEPS=16;
let pads=[], flStep=-1, flPlaying=false, flBPM=120, flInt=null, audioCtx=null;

function initFL() {
  pads=FL_TRACKS.map(()=>Array(STEPS).fill(false));
  // Default pattern
  [0,4,8,12].forEach(s=>pads[0][s]=true);
  [4,12].forEach(s=>pads[1][s]=true);
  [2,6,10,14].forEach(s=>pads[2][s]=true);
  [0,6,10].forEach(s=>pads[3][s]=true);
  renderFL();
}

function renderFL() {
  const cont=document.getElementById('fl-container');
  let h=`<div class="fl-toolbar">
    <button class="fl-toolbar-btn" id="fl-play" onclick="flToggle()">▶ Play</button>
    <button class="fl-toolbar-btn" onclick="flStop()">⏹ Stop</button>
    <button class="fl-toolbar-btn" onclick="flClear()">✕ Clear</button>
    <span class="fl-bpm">BPM: <span class="fl-bpm-value" id="fl-bpm-disp">${flBPM}</span></span>
    <input type="range" min="60" max="200" value="${flBPM}" style="width:55px;cursor:pointer" oninput="flSetBPM(this.value)" />
  </div>
  <div class="fl-step-header">
    <div></div>
    ${Array.from({length:STEPS},(_,i)=>`<div class="fl-step-num${i%4===0?' beat':''}">${i+1}</div>`).join('')}
  </div>`;
  FL_TRACKS.forEach((t,ti)=>{
    h+=`<div class="fl-track"><div class="fl-track-name">${t.name}</div>
    ${Array.from({length:STEPS},(_,si)=>
      `<div class="fl-pad ${t.cls} ${pads[ti][si]?'active':''}" id="fp-${ti}-${si}" onclick="flTogglePad(${ti},${si})"></div>`
    ).join('')}</div>`;
  });
  cont.innerHTML=h;
}

function flTogglePad(ti,si) {
  pads[ti][si]=!pads[ti][si];
  const el=document.getElementById(`fp-${ti}-${si}`);
  if(el) el.classList.toggle('active',pads[ti][si]);
}

function flToggle() { flPlaying ? flStop() : flStart(); }

function flStart() {
  flPlaying=true;
  const btn=document.getElementById('fl-play');
  if(btn){btn.textContent='⏸ Pause';btn.classList.add('playing');}
  if(!audioCtx) audioCtx=new(window.AudioContext||window.webkitAudioContext)();
  flStep=0;
  flInt=setInterval(()=>{flTick();flStep=(flStep+1)%STEPS;}, (60/flBPM/4)*1000);
}

function flStop() {
  flPlaying=false; clearInterval(flInt); flStep=-1;
  const btn=document.getElementById('fl-play');
  if(btn){btn.textContent='▶ Play';btn.classList.remove('playing');}
  document.querySelectorAll('.fl-pad.current').forEach(p=>p.classList.remove('current'));
}

function flClear() { flStop(); pads=FL_TRACKS.map(()=>Array(STEPS).fill(false)); renderFL(); }

function flSetBPM(v) {
  flBPM=parseInt(v);
  const el=document.getElementById('fl-bpm-disp');
  if(el) el.textContent=flBPM;
  if(flPlaying){flStop();flStart();}
}

function flTick() {
  const s=flStep;
  document.querySelectorAll('.fl-pad').forEach(p=>p.classList.remove('current'));
  FL_TRACKS.forEach((_,ti)=>{
    const el=document.getElementById(`fp-${ti}-${s}`);
    if(el) el.classList.add('current');
    if(pads[ti][s]) playDrum(ti);
  });
}

function playDrum(ti) {
  if(!audioCtx) return;
  const now=audioCtx.currentTime;
  if(ti===0) { // Kick
    const o=audioCtx.createOscillator(), g=audioCtx.createGain();
    o.connect(g); g.connect(audioCtx.destination);
    o.frequency.setValueAtTime(150,now);
    o.frequency.exponentialRampToValueAtTime(30,now+0.15);
    g.gain.setValueAtTime(1,now); g.gain.exponentialRampToValueAtTime(0.001,now+0.3);
    o.start(now); o.stop(now+0.3);
  } else if(ti===1) { // Snare
    const buf=audioCtx.createBuffer(1,audioCtx.sampleRate*0.15,audioCtx.sampleRate);
    const d=buf.getChannelData(0); for(let i=0;i<d.length;i++) d[i]=Math.random()*2-1;
    const src=audioCtx.createBufferSource(), g=audioCtx.createGain();
    g.gain.setValueAtTime(0.5,now); g.gain.exponentialRampToValueAtTime(0.001,now+0.15);
    src.buffer=buf; src.connect(g); g.connect(audioCtx.destination); src.start(now);
  } else if(ti===2) { // Hi-hat
    const buf=audioCtx.createBuffer(1,audioCtx.sampleRate*0.04,audioCtx.sampleRate);
    const d=buf.getChannelData(0); for(let i=0;i<d.length;i++) d[i]=Math.random()*2-1;
    const src=audioCtx.createBufferSource(), f=audioCtx.createBiquadFilter(), g=audioCtx.createGain();
    f.type='highpass'; f.frequency.value=8000;
    g.gain.setValueAtTime(0.25,now); g.gain.exponentialRampToValueAtTime(0.001,now+0.04);
    src.buffer=buf; src.connect(f); f.connect(g); g.connect(audioCtx.destination); src.start(now);
  } else if(ti===3) { // Bass
    const o=audioCtx.createOscillator(), g=audioCtx.createGain();
    o.type='sine'; o.frequency.value=80;
    g.gain.setValueAtTime(0.6,now); g.gain.exponentialRampToValueAtTime(0.001,now+0.25);
    o.connect(g); g.connect(audioCtx.destination); o.start(now); o.stop(now+0.25);
  }
}

