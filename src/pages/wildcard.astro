---
// wildcard.astro — Windows XP desktop using XP.css
// Customize: songs in TRACKS[], apps in the window HTML sections below
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Jesse Vaughan — Wildcard.exe</title>

  <!-- XP.css — authentic Windows XP chrome -->
  <link rel="stylesheet" href="https://unpkg.com/xp.css@0.2.3/dist/XP.css" />

  <style>
    /* ─── RESET & BASE ─── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { width: 100%; height: 100%; overflow: hidden; font-family: Tahoma, Arial, sans-serif; font-size: 11px; }

    /* ─── DESKTOP ─── */
    #desktop {
      position: absolute; inset: 0 0 30px 0;
      /* Joshua Tree desert gradient wallpaper */
      background: linear-gradient(175deg,
        #6a9fc0 0%, #9ac0d8 18%,
        #c8a870 48%, #b87840 68%,
        #7a5020 85%, #5a3810 100%);
      overflow: hidden;
    }

    /* ─── DESKTOP ICONS ─── */
    .icons {
      position: absolute; top: 12px; left: 12px;
      display: flex; flex-direction: column; gap: 4px;
    }
    .icon {
      width: 72px; display: flex; flex-direction: column; align-items: center;
      padding: 4px; border: 1px dotted transparent; border-radius: 2px;
      cursor: pointer; color: white; text-align: center; gap: 3px;
      text-shadow: 1px 1px 1px #000, 0 0 5px rgba(0,0,0,0.8);
    }
    .icon:hover { background: rgba(49,106,197,0.4); border-color: rgba(255,255,255,0.6); }
    .icon .ico { font-size: 28px; line-height: 1; }
    .icon .lbl { font-size: 10px; line-height: 1.3; }

    /* ─── WINDOWS ─── */
    .xp-win {
      position: absolute; display: none;
      /* XP.css handles all the chrome styling via .window class */
    }
    /* Override XP.css default width */
    .xp-win .window { width: 100%; margin: 0; }

    /* ─── TASKBAR ─── */
    #taskbar {
      position: fixed; bottom: 0; left: 0; right: 0; height: 30px;
      background: linear-gradient(to bottom, #3270e8 0%, #1e58d0 45%, #1848b8 50%, #1040a8 100%);
      border-top: 2px solid #5898f8;
      display: flex; align-items: center; z-index: 9000; gap: 2px; padding: 0 2px;
    }
    #start-btn {
      height: 24px; padding: 0 12px 0 8px;
      background: linear-gradient(to bottom, #68c868, #40a840 35%, #308830 65%, #287028);
      border: 1px solid #1a5018; border-radius: 0 14px 14px 0;
      color: white; font-size: 13px; font-weight: bold; cursor: pointer;
      display: flex; align-items: center; gap: 5px;
      text-shadow: 1px 1px 2px rgba(0,0,0,0.5); font-family: Tahoma, sans-serif;
      box-shadow: 0 1px 0 rgba(255,255,255,0.4) inset;
    }
    #start-btn:hover { filter: brightness(1.1); }
    #start-btn:active { filter: brightness(0.85); }
    #tb-apps { flex: 1; display: flex; align-items: center; gap: 2px; overflow: hidden; padding: 0 4px; }
    .tb-btn {
      height: 22px; padding: 0 8px; max-width: 140px; overflow: hidden;
      background: linear-gradient(to bottom, #3a78e8, #1e50c0);
      border: 1px solid rgba(255,255,255,0.2); border-radius: 3px;
      color: white; font-size: 10px; cursor: pointer;
      display: flex; align-items: center; gap: 4px; white-space: nowrap;
    }
    .tb-btn:hover { filter: brightness(1.15); }
    .tb-btn.active { background: linear-gradient(to bottom, #1040a0, #083080); box-shadow: 1px 1px 4px rgba(0,0,0,0.5) inset; }
    #systray {
      height: 100%; padding: 0 10px; display: flex; align-items: center; gap: 8px;
      border-left: 1px solid rgba(255,255,255,0.15); background: rgba(0,0,0,0.15);
      color: white; font-size: 11px; white-space: nowrap;
    }

    /* ─── START MENU ─── */
    #smenu {
      position: fixed; bottom: 30px; left: 0; width: 290px;
      background: white; display: none;
      border: 1px solid #0040c0; border-radius: 8px 8px 0 0;
      box-shadow: 4px -4px 20px rgba(0,0,0,0.5); z-index: 9001; overflow: hidden;
    }
    #smenu.open { display: block; }
    .sm-head { background: linear-gradient(to right, #0848d8, #1878ff); padding: 10px 14px; display: flex; align-items: center; gap: 12px; }
    .sm-av { width: 42px; height: 42px; border-radius: 4px; background: rgba(255,255,255,0.2); display: flex; align-items: center; justify-content: center; font-size: 28px; border: 2px solid rgba(255,255,255,0.4); }
    .sm-name { font-size: 16px; font-weight: bold; color: white; text-shadow: 1px 1px 2px rgba(0,0,0,0.4); }
    .sm-body { padding: 6px 0; border-bottom: 2px solid #d0ccc0; }
    .sm-item { padding: 6px 14px; display: flex; align-items: center; gap: 10px; cursor: pointer; font-size: 12px; }
    .sm-item:hover { background: #316ac5; color: white; }
    .sm-icon { font-size: 18px; }
    .sm-div { height: 1px; background: #d0ccc0; margin: 4px 14px; }
    .sm-foot { background: #d4d0c8; padding: 6px 14px; display: flex; justify-content: flex-end; border-top: 1px solid #b8b4ac; }
    .sm-foot button { background: none; border: none; cursor: pointer; font-size: 11px; }

    /* ─── ERROR POPUP ─── */
    #err-popup { position: fixed; display: none; z-index: 20000; width: 340px; }
    #err-popup.show { display: block; }

    /* ─── WINAMP APP ─── */
    .wa-wrap { background: #232323; }
    .wa-display { background: #000; margin: 5px; border: 1px solid #2a2a2a; padding: 6px 8px; }
    .wa-track { color: #00cc00; font-family: monospace; font-size: 9px; white-space: nowrap; overflow: hidden; margin-bottom: 3px; }
    .wa-row { display: flex; justify-content: space-between; align-items: flex-end; }
    .wa-time { color: #00ff00; font-family: monospace; font-size: 20px; letter-spacing: 3px; font-weight: bold; }
    .wa-viz { display: flex; gap: 1px; height: 22px; align-items: flex-end; }
    .wa-bar { width: 3px; background: #00ee00; border-radius: 1px 1px 0 0; animation: vzbar 0.1s ease-in-out infinite alternate; }
    @keyframes vzbar { from { height: var(--lo); } to { height: var(--hi); } }
    .wa-ctrl { display: flex; align-items: center; padding: 4px 6px; gap: 3px; background: #1c1c1c; }
    .wa-ctrl button { background: #383838; border: 1px solid #555; color: #ccc; font-size: 10px; padding: 2px 6px; cursor: pointer; border-radius: 2px; font-family: monospace; }
    .wa-ctrl button:hover { background: #484848; }
    .wa-ctrl button:active { background: #111; }
    .wa-vol { flex: 1; height: 4px; background: #333; margin-left: 6px; border-radius: 2px; overflow: hidden; }
    .wa-vf { width: 75%; height: 100%; background: linear-gradient(to right, #00aa00, #00ff00); }
    .wa-list { border-top: 1px solid #2a2a2a; background: #0c0c0c; max-height: 130px; overflow-y: auto; }
    .wa-li { padding: 3px 8px; color: #666; cursor: pointer; display: flex; gap: 6px; font-family: monospace; font-size: 10px; }
    .wa-li.now { color: #00ff00; background: #001800; }
    .wa-li:hover { background: #181818; color: #aaa; }
    .wa-li.now:hover { background: #002000; }
    .wa-num { color: #444; min-width: 18px; }

    /* ─── MTG APP ─── */
    .mtg-body { background: #0e0600; padding: 10px; display: flex; flex-direction: column; align-items: center; gap: 8px; font-family: 'Times New Roman', serif; }
    .mtg-title { font-size: 13px; font-weight: bold; color: #d4a050; text-shadow: 0 0 10px rgba(212,160,80,0.6); }
    .mtg-sets { display: flex; gap: 5px; }
    .mtg-set-btn { background: #1a0a00; border: 1px solid #6a4010; color: #b09050; padding: 3px 8px; font-size: 10px; cursor: pointer; border-radius: 3px; font-family: Tahoma, sans-serif; }
    .mtg-set-btn:hover { background: #2e1400; }
    .mtg-set-btn.active { background: #2e1400; border-color: #c8a050; color: #e8c068; }
    .mtg-card { width: 182px; height: 254px; border: 2px solid #6a4010; border-radius: 10px; overflow: hidden; background: #080300; display: flex; align-items: center; justify-content: center; }
    .mtg-card img { width: 100%; height: 100%; object-fit: cover; border-radius: 8px; }
    .mtg-loading { color: #6a4010; font-size: 11px; text-align: center; padding: 10px; font-family: Tahoma, sans-serif; }
    .mtg-draw { background: linear-gradient(to bottom, #3a1e00, #1e0800); border: 2px solid #c8a050; color: #e8c068; padding: 7px 18px; font-size: 12px; cursor: pointer; border-radius: 4px; font-family: 'Times New Roman', serif; font-weight: bold; }
    .mtg-draw:hover { background: linear-gradient(to bottom, #5a2e00, #2e1000); }
    .mtg-draw:active { filter: brightness(0.85); }
    .mtg-name { color: #c8a050; font-size: 10px; text-align: center; font-family: Tahoma, sans-serif; min-height: 14px; }

    /* ─── MINESWEEPER ─── */
    /* XP.css styles buttons/inputs; we handle the grid */
    .ms-body { background: #c0c0c0; padding: 8px; user-select: none; }
    .ms-head { background: #c0c0c0; border: 3px solid; border-color: #fff #808080 #808080 #fff; padding: 4px 6px; display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px; }
    .ms-count { background: #000; color: #f00; font-family: monospace; font-size: 20px; padding: 1px 4px; min-width: 46px; text-align: right; letter-spacing: 2px; }
    .ms-face { width: 28px; height: 28px; background: #c0c0c0; border: 3px solid; border-color: #fff #808080 #808080 #fff; cursor: pointer; font-size: 16px; display: flex; align-items: center; justify-content: center; }
    .ms-face:active { border-color: #808080 #fff #fff #808080; }
    .ms-grid { border: 3px solid; border-color: #808080 #fff #fff #808080; display: inline-grid; }
    .ms-cell { width: 22px; height: 22px; background: #c0c0c0; border: 2px solid; border-color: #fff #808080 #808080 #fff; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: bold; cursor: pointer; }
    .ms-cell.open { border: 1px solid #808080; cursor: default; }
    .ms-cell.dead { background: #f00; }
    .n1{color:#00f}.n2{color:#080}.n3{color:#f00}.n4{color:#000080}.n5{color:#800000}.n6{color:#008080}.n7{color:#000}.n8{color:#808080}

    /* ─── AIM ─── */
    .aim-head { background: linear-gradient(to bottom, #5599ee, #2266cc); padding: 6px 8px; display: flex; align-items: center; gap: 8px; }
    .aim-logo { font-size: 22px; }
    .aim-headtxt { color: #fff; font-weight: bold; font-size: 12px; }
    .aim-bar { background: #e0ecff; padding: 5px 8px; border-bottom: 1px solid #c0d4f0; }
    .aim-sn { font-weight: bold; color: #1144aa; font-size: 13px; }
    .aim-status { color: #666; font-size: 9px; }
    .aim-away { background: #ffffe0; border: 1px solid #c8c860; margin: 6px; padding: 6px 8px; font-size: 11px; color: #444; font-style: italic; }
    .aim-away-lbl { font-size: 9px; font-weight: bold; font-style: normal; color: #888; margin-bottom: 2px; }
    .aim-group-hdr { background: #c8d8f0; padding: 3px 8px; font-weight: bold; color: #1144aa; font-size: 10px; display: flex; justify-content: space-between; }
    .aim-buddy { padding: 3px 16px; display: flex; align-items: center; gap: 7px; cursor: pointer; font-size: 11px; }
    .aim-buddy:hover { background: #e8f0ff; }
    .aim-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
    .dot-on { background: #00aa00; }
    .dot-aw { background: #ffaa00; }
    .dot-off { background: #aaa; }

    /* ─── DIABLO II ─── */
    .d2-body { background: #080300; color: #c8a050; font-family: 'Times New Roman', serif; padding: 10px; }
    .d2-logo { color: #cc2000; font-size: 20px; font-weight: bold; text-align: center; text-shadow: 0 0 15px rgba(200,32,0,0.9); letter-spacing: 4px; }
    .d2-sub { color: #555040; font-size: 9px; text-align: center; letter-spacing: 3px; margin-bottom: 10px; }
    .d2-char { display: flex; gap: 10px; }
    .d2-portrait { width: 80px; height: 110px; background: #100600; border: 2px solid #3a1800; display: flex; align-items: center; justify-content: center; font-size: 52px; flex-shrink: 0; }
    .d2-info { flex: 1; }
    .d2-name { color: #e8d080; font-size: 15px; font-weight: bold; }
    .d2-class { color: #6a5030; font-size: 9px; letter-spacing: 2px; margin-bottom: 7px; }
    .d2-stat { display: flex; justify-content: space-between; padding: 2px 0; border-bottom: 1px solid #180c00; font-size: 11px; }
    .d2-stat-l { color: #907050; }
    .d2-stat-v { color: #e8c070; font-weight: bold; }
    .d2-skills-hdr { color: #cc2000; font-size: 10px; letter-spacing: 2px; margin: 8px 0 4px; text-shadow: 0 0 6px rgba(200,32,0,0.5); }
    .d2-skill { display: flex; align-items: center; gap: 6px; padding: 2px 0; font-size: 10px; }
    .d2-skill-name { color: #b09060; flex: 1; }
    .d2-bar { width: 80px; height: 8px; background: #130800; border: 1px solid #3a1800; border-radius: 2px; overflow: hidden; }
    .d2-fill { height: 100%; background: linear-gradient(to right, #aa1800, #ff4000); }
    .d2-lvl { color: #c8a050; min-width: 20px; text-align: right; }

    /* ─── FRUITYLOOPS ─── */
    .fl-body { background: #222; color: #ccc; font-size: 10px; padding: 8px; }
    .fl-toolbar { display: flex; align-items: center; gap: 5px; margin-bottom: 8px; padding-bottom: 6px; border-bottom: 1px solid #333; flex-wrap: wrap; }
    .fl-btn { background: linear-gradient(to bottom, #404040, #282828); border: 1px solid #555; color: #ccc; padding: 3px 8px; font-size: 10px; cursor: pointer; border-radius: 2px; font-family: Tahoma, sans-serif; }
    .fl-btn:hover { background: linear-gradient(to bottom, #505050, #383838); }
    .fl-btn:active { background: #111; }
    .fl-btn.playing { background: linear-gradient(to bottom, #185018, #0c3a0c); color: #0f0; border-color: #0a0; }
    .fl-bpm-label { color: #666; }
    .fl-bpm-val { color: #0c0; font-weight: bold; }
    .fl-nums { display: grid; grid-template-columns: 64px repeat(16, 1fr); gap: 1px; margin-bottom: 2px; }
    .fl-num { text-align: center; color: #444; font-size: 8px; }
    .fl-num.beat { color: #666; font-weight: bold; }
    .fl-row { display: grid; grid-template-columns: 64px repeat(16, 1fr); gap: 1px; margin-bottom: 2px; }
    .fl-label { background: #181818; border: 1px solid #333; padding: 3px 5px; font-size: 9px; color: #aaa; display: flex; align-items: center; border-radius: 2px; }
    .fl-pad { height: 20px; background: #161616; border: 1px solid #252525; cursor: pointer; border-radius: 2px; }
    .fl-pad:hover { background: #252525; }
    .fl-pad.on.kick  { background: #602000; border-color: #f05000; box-shadow: 0 0 4px rgba(240,80,0,0.4); }
    .fl-pad.on.snare { background: #585000; border-color: #f0c000; box-shadow: 0 0 4px rgba(240,192,0,0.4); }
    .fl-pad.on.hihat { background: #102860; border-color: #2878f0; box-shadow: 0 0 4px rgba(40,120,240,0.4); }
    .fl-pad.on.bass  { background: #300a58; border-color: #9830f0; box-shadow: 0 0 4px rgba(152,48,240,0.4); }
    .fl-pad.step { filter: brightness(2.2); }
  </style>
</head>
<body>

<!-- ═══════════════════════════ DESKTOP ═══════════════════════════ -->
<div id="desktop">
  <div class="icons">
    <div class="icon" ondblclick="openApp('wa')">    <div class="ico">🎵</div><div class="lbl">Winamp 2.95</div></div>
    <div class="icon" ondblclick="openApp('mtg')">   <div class="ico">🃏</div><div class="lbl">MTG Collection</div></div>
    <div class="icon" ondblclick="openApp('ms')">    <div class="ico">💣</div><div class="lbl">Minesweeper</div></div>
    <div class="icon" ondblclick="openApp('aim')">   <div class="ico">💬</div><div class="lbl">AIM 5.9</div></div>
    <div class="icon" ondblclick="openApp('d2')">    <div class="ico">⚔️</div><div class="lbl">Diablo II</div></div>
    <div class="icon" ondblclick="openApp('fl')">    <div class="ico">🎹</div><div class="lbl">FruityLoops 3.4</div></div>
    <div class="icon" ondblclick="location.href='/'"><div class="ico">🌐</div><div class="lbl">jessevaughan.com</div></div>
  </div>
</div>


<!-- ═══════════════════════════ APP WINDOWS ═══════════════════════════
     Each window: .xp-win wrapper (handles position/show/hide)
                  .window (XP.css class — handles all chrome styling)
     ═══════════════════════════════════════════════════════════════ -->

<!-- ── WINAMP ── -->
<div class="xp-win" id="app-wa" style="top:60px; left:60px; width:310px;">
  <div class="window">
    <div class="title-bar" onmousedown="dragStart(event,'app-wa')">
      <div class="title-bar-text">🎵 Winamp 2.95</div>
      <div class="title-bar-controls">
        <button aria-label="Minimize" onclick="minimizeApp('app-wa')"></button>
        <button aria-label="Maximize"></button>
        <button aria-label="Close" onclick="closeApp('app-wa')"></button>
      </div>
    </div>
    <div class="window-body" style="padding:0">
      <div class="wa-wrap">
        <div class="wa-display">
          <div class="wa-track" id="wa-track">▶ Boards of Canada - Aquarius</div>
          <div class="wa-row">
            <div class="wa-time" id="wa-time">2:14</div>
            <div class="wa-viz" id="wa-viz"></div>
          </div>
        </div>
        <div class="wa-ctrl">
          <button onclick="waPrev()">|◀</button>
          <button id="wa-pb" onclick="waToggle()">▐▐</button>
          <button onclick="waNext()">▶|</button>
          <button>■</button>
          <div class="wa-vol"><div class="wa-vf"></div></div>
        </div>
        <div class="wa-list" id="wa-list">
          <!-- Playlist items injected by JS — edit TRACKS array below -->
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ── MTG COLLECTION ── -->
<div class="xp-win" id="app-mtg" style="top:50px; left:560px; width:222px;">
  <div class="window" style="background:#0e0600; border-color:#6a3008;">
    <div class="title-bar" onmousedown="dragStart(event,'app-mtg')" style="background:linear-gradient(to right,#801008,#601008);">
      <div class="title-bar-text">🃏 MTG Collection</div>
      <div class="title-bar-controls">
        <button aria-label="Minimize" onclick="minimizeApp('app-mtg')"></button>
        <button aria-label="Maximize"></button>
        <button aria-label="Close" onclick="closeApp('app-mtg')"></button>
      </div>
    </div>
    <div class="window-body" style="padding:0">
      <div class="mtg-body">
        <div class="mtg-title">⚔ The Gathering ⚔</div>
        <!-- Add/remove set buttons to change which sets are available -->
        <div class="mtg-sets">
          <button class="mtg-set-btn active" onclick="setMtgSet('ice',this)">Ice Age</button>
          <button class="mtg-set-btn" onclick="setMtgSet('5ed',this)">5th Ed.</button>
          <button class="mtg-set-btn" onclick="setMtgSet('all',this)">Alliances</button>
        </div>
        <div class="mtg-card" id="mtg-card">
          <div class="mtg-loading">Shuffling library...</div>
        </div>
        <div class="mtg-name" id="mtg-name"></div>
        <button class="mtg-draw" onclick="drawMtgCard()">✦ Draw Card ✦</button>
      </div>
    </div>
  </div>
</div>

<!-- ── MINESWEEPER ── -->
<div class="xp-win" id="app-ms" style="top:380px; left:800px;">
  <div class="window">
    <div class="title-bar" onmousedown="dragStart(event,'app-ms')">
      <div class="title-bar-text">💣 Minesweeper</div>
      <div class="title-bar-controls">
        <button aria-label="Minimize" onclick="minimizeApp('app-ms')"></button>
        <button aria-label="Maximize"></button>
        <button aria-label="Close" onclick="closeApp('app-ms')"></button>
      </div>
    </div>
    <div class="window-body" style="padding:0">
      <div class="ms-body" id="ms-body"><!-- injected --></div>
    </div>
  </div>
</div>

<!-- ── AIM ── -->
<div class="xp-win" id="app-aim" style="top:50px; left:812px; width:210px;">
  <div class="window">
    <div class="title-bar" onmousedown="dragStart(event,'app-aim')">
      <div class="title-bar-text">💬 AIM 5.9</div>
      <div class="title-bar-controls">
        <button aria-label="Minimize" onclick="minimizeApp('app-aim')"></button>
        <button aria-label="Maximize"></button>
        <button aria-label="Close" onclick="closeApp('app-aim')"></button>
      </div>
    </div>
    <div class="window-body" style="padding:0">
      <div class="aim-head"><span class="aim-logo">🔵</span><span class="aim-headtxt">AOL Instant Messenger</span></div>
      <div class="aim-bar">
        <div class="aim-sn">DesignNerd87</div>
        <div class="aim-status">Online — <span id="aim-timer">0:00:00</span></div>
      </div>
      <div class="aim-away">
        <div class="aim-away-lbl">AWAY MESSAGE:</div>
        <!-- ✏️ CUSTOMIZE: change this away message -->
        brb, making beats in the garage. might also be playing d2. probably both.
      </div>
      <div class="aim-group-hdr"><span>Buddies (4/6)</span><span>▼</span></div>
      <!-- ✏️ CUSTOMIZE: swap in real/fake buddy names + statuses -->
      <div class="aim-buddy"><div class="aim-dot dot-on"></div>xXShadowmage99Xx</div>
      <div class="aim-buddy"><div class="aim-dot dot-on"></div>KazaaQueen2002</div>
