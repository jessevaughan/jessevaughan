---
// wildcard.astro — No layout, full standalone XP desktop
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Jesse Vaughan — Wildcard.exe</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    html, body {
      width: 100%; height: 100%;
      overflow: hidden;
      font-family: Tahoma, Arial, sans-serif;
      font-size: 11px;
    }

    /* ── DESKTOP ── */
    #desktop {
      width: 100%;
      height: calc(100% - 30px);
      background: linear-gradient(180deg,
        #7aaccc 0%, #a8cce0 25%,
        #d4b88a 55%, #c4956a 72%,
        #8c6030 88%, #6a4820 100%);
      position: relative;
      overflow: hidden;
    }

    /* subtle grain on desktop */
    #desktop::before {
      content: '';
      position: absolute; inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.07'/%3E%3C/svg%3E");
      pointer-events: none; z-index: 0;
    }

    /* ── DESKTOP ICONS ── */
    .desktop-icons {
      position: absolute; top: 12px; left: 12px;
      display: flex; flex-direction: column; gap: 6px;
      z-index: 1;
    }

    .desktop-icon {
      display: flex; flex-direction: column; align-items: center;
      width: 72px; padding: 4px; cursor: pointer;
      border: 1px solid transparent; border-radius: 3px;
      color: white;
      text-shadow: 1px 1px 2px #000, -1px -1px 2px #000, 0 0 4px #000;
      text-align: center;
    }
    .desktop-icon:hover { background: rgba(49,106,197,0.4); border-color: rgba(255,255,255,0.5); }
    .desktop-icon .icon-img { font-size: 30px; margin-bottom: 3px; line-height: 1; }
    .desktop-icon .icon-label { font-size: 10px; line-height: 1.2; }

    /* ── WINDOW ── */
    .window {
      position: absolute;
      display: none;
      flex-direction: column;
      border: 2px solid #003cc4;
      border-radius: 8px 8px 0 0;
      box-shadow: 3px 3px 12px rgba(0,0,0,0.6);
      overflow: hidden;
      min-width: 180px;
    }
    .window.inactive { border-color: #7a96df; }

    .window-titlebar {
      background: linear-gradient(to bottom, #2b7fe5 0%, #1358d0 100%);
      color: white; padding: 3px 5px;
      display: flex; align-items: center;
      cursor: move; user-select: none;
      font-weight: bold; font-size: 11px;
      height: 26px; flex-shrink: 0; gap: 4px;
    }
    .window.inactive .window-titlebar {
      background: linear-gradient(to bottom, #7a96df, #6484c8);
    }
    .window-title-text { flex: 1; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

    .window-controls { display: flex; gap: 2px; flex-shrink: 0; }
    .win-btn {
      width: 21px; height: 18px; border: 1px solid rgba(255,255,255,0.4);
      border-radius: 3px; font-size: 10px; cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      color: white; font-weight: bold; user-select: none;
    }
    .win-btn.minimize, .win-btn.maximize { background: linear-gradient(to bottom, #6ea8f0, #4080d8); }
    .win-btn.close { background: linear-gradient(to bottom, #e05050, #c02020); }
    .win-btn:hover.close { background: linear-gradient(to bottom, #ff6060, #e03030); }

    .window-body { background: #ece9d8; flex: 1; overflow: auto; }

    /* ── TASKBAR ── */
    #taskbar {
      position: fixed; bottom: 0; left: 0; right: 0; height: 30px;
      background: linear-gradient(to bottom, #245edb, #1848c0);
      display: flex; align-items: center; z-index: 10000;
      padding: 0 2px; gap: 2px;
    }

    #start-btn {
      background: linear-gradient(to bottom, #4caf50, #2e7d32);
      color: white; border: 1px solid #1b5e20;
      border-radius: 12px 0 0 12px;
      padding: 3px 10px 3px 6px;
      font-family: Tahoma, Arial, sans-serif;
      font-size: 13px; font-weight: bold; cursor: pointer;
      height: 24px; display: flex; align-items: center; gap: 4px;
    }
    #start-btn:hover { background: linear-gradient(to bottom, #66bb6a, #388e3c); }

    #taskbar-apps { flex: 1; display: flex; align-items: center; gap: 2px; overflow: hidden; }

    .taskbar-app {
      height: 22px;
      background: linear-gradient(to bottom, #3a78e8, #2456c0);
      border: 1px solid rgba(255,255,255,0.25);
      border-radius: 3px; color: white; font-size: 10px;
      padding: 0 8px; cursor: pointer;
      display: flex; align-items: center; gap: 4px;
      white-space: nowrap; max-width: 140px; overflow: hidden;
    }
    .taskbar-app:hover { background: linear-gradient(to bottom, #4a88f8, #3466d0); }
    .taskbar-app.focused {
      background: linear-gradient(to bottom, #1a58c8, #0a3a90);
      box-shadow: inset 1px 1px 3px rgba(0,0,0,0.4);
    }

    #systray {
      background: linear-gradient(to bottom, #1a48b8, #0e32a0);
      height: 100%; display: flex; align-items: center;
      padding: 0 8px; border-left: 1px solid rgba(255,255,255,0.2);
      color: white; font-size: 11px; gap: 6px;
    }

    /* ── START MENU ── */
    #start-menu {
      position: fixed; bottom: 30px; left: 0; width: 280px;
      background: white; border: 1px solid #003cc4;
      border-radius: 8px 8px 0 0;
      box-shadow: 4px -4px 16px rgba(0,0,0,0.5);
      z-index: 10001; display: none; overflow: hidden;
    }
    #start-menu.open { display: block; }

    .start-menu-header {
      background: linear-gradient(to right, #0858d8, #1a78f0);
      color: white; padding: 10px 12px; font-size: 16px; font-weight: bold;
      display: flex; align-items: center; gap: 10px;
    }
    .start-menu-avatar {
      width: 40px; height: 40px; border-radius: 4px;
      background: rgba(255,255,255,0.25);
      display: flex; align-items: center; justify-content: center;
      font-size: 26px;
    }
    .start-menu-items { padding: 6px 0; }
    .start-menu-item {
      padding: 5px 14px; display: flex; align-items: center;
      gap: 10px; cursor: pointer; font-size: 12px;
    }
    .start-menu-item:hover { background: #316ac5; color: white; }
    .start-menu-item .item-icon { font-size: 18px; }
    .start-menu-divider { height: 1px; background: #d4d0c8; margin: 4px 0; }
    .start-menu-footer {
      background: #d4d0c8; padding: 6px 12px;
      display: flex; justify-content: flex-end;
      border-top: 1px solid #b0aca0;
    }
    .start-menu-footer button {
      background: none; border: none; cursor: pointer;
      font-size: 11px; display: flex; align-items: center; gap: 4px;
    }

    /* ── ERROR POPUP ── */
    .error-popup {
      position: fixed; background: #ece9d8;
      border: 2px solid #0058e0; border-radius: 8px 8px 0 0;
      box-shadow: 4px 4px 12px rgba(0,0,0,0.6);
      z-index: 9999; width: 300px; display: none;
      font-family: Tahoma, Arial, sans-serif; font-size: 11px;
    }
    .error-popup.visible { display: block; }
    .error-titlebar {
      background: linear-gradient(to bottom, #c02020, #900000);
      color: white; padding: 3px 6px;
      display: flex; align-items: center;
      font-weight: bold; font-size: 11px; height: 26px; gap: 4px;
    }
    .error-body { padding: 12px 16px; display: flex; gap: 12px; align-items: flex-start; }
    .error-icon { font-size: 24px; flex-shrink: 0; }
    .error-btn-row { padding: 6px 16px 10px; display: flex; justify-content: center; gap: 6px; }
    .error-btn {
      background: #ece9d8; border: 1px solid #888;
      padding: 3px 14px; font-size: 11px; cursor: pointer; min-width: 56px;
    }
    .error-btn:hover { background: #dedad0; }

    /* ══════════════════════════════
       APP STYLES
       ══════════════════════════════ */

    /* WINAMP */
    .winamp { background: #232323; color: #00ff00; font-family: 'Courier New', monospace; font-size: 10px; }
    .winamp-display { background: #000; padding: 6px 8px; margin: 6px; border: 1px solid #333; }
    .winamp-track { color: #00cc00; font-size: 10px; white-space: nowrap; overflow: hidden; margin-bottom: 4px; }
    .winamp-time { color: #00ff00; font-size: 18px; letter-spacing: 3px; }
    .winamp-viz { display: flex; gap: 2px; height: 22px; align-items: flex-end; margin-top: 4px; }
    .winamp-viz-bar { width: 3px; background: #00ff00; animation: vizBar 0.12s ease-in-out infinite alternate; }
    @keyframes vizBar { from { height: var(--h1, 4px); } to { height: var(--h2, 16px); } }
    .winamp-controls { display: flex; align-items: center; padding: 4px 8px; gap: 3px; }
    .winamp-btn {
      background: #3a3a3a; border: 1px solid #555;
      color: #ccc; font-size: 10px; padding: 2px 5px; cursor: pointer; border-radius: 2px;
    }
    .winamp-btn:hover { background: #4a4a4a; }
    .winamp-volume { flex: 1; height: 4px; background: #444; margin-left: 6px; border-radius: 2px; }
    .winamp-vol-fill { width: 75%; height: 100%; background: #00cc00; border-radius: 2px; }
    .winamp-playlist { border-top: 1px solid #333; padding: 4px 8px; max-height: 110px; overflow-y: auto; }
    .winamp-playlist-item { padding: 2px 0; color: #666; cursor: pointer; display: flex; gap: 6px; }
    .winamp-playlist-item.active { color: #00ff00; }
    .winamp-playlist-item:hover { color: #aaa; }
    .winamp-track-num { color: #444; min-width: 18px; }

    /* MTG */
    .mtg-viewer {
      background: #120800; color: #c8a060;
      font-family: 'Times New Roman', serif;
      padding: 10px; display: flex; flex-direction: column; align-items: center; gap: 8px;
    }
    .mtg-title { font-size: 13px; font-weight: bold; color: #d4a860; text-align: center; text-shadow: 0 0 8px rgba(200,160,80,0.5); }
    .mtg-set-selector { display: flex; gap: 6px; }
    .mtg-set-btn {
      background: #200d00; border: 1px solid #7a5020;
      color: #c8a060; padding: 3px 8px; font-size: 10px; cursor: pointer; border-radius: 3px;
    }
    .mtg-set-btn:hover, .mtg-set-btn.active { background: #3a1a00; border-color: #c8a060; color: #f0c878; }
    .mtg-card-display {
      width: 180px; height: 252px;
      border: 2px solid #7a5020; border-radius: 8px;
      overflow: hidden; display: flex; align-items: center; justify-content: center;
      background: #0a0400;
    }
    .mtg-card-display img { width: 100%; height: 100%; object-fit: cover; }
    .mtg-card-loading { color: #7a5020; font-size: 12px; text-align: center; padding: 10px; }
    .mtg-draw-btn {
      background: linear-gradient(to bottom, #3a1e00, #200e00);
      border: 2px solid #c8a060; color: #f0c878;
      padding: 6px 16px; font-size: 12px; cursor: pointer;
      border-radius: 4px; font-family: 'Times New Roman', serif; font-weight: bold;
    }
    .mtg-draw-btn:hover { background: linear-gradient(to bottom, #5a2e00, #3a1800); }

    /* MINESWEEPER */
    .minesweeper { background: #c0c0c0; padding: 8px; user-select: none; }
    .ms-header {
      background: #c0c0c0; border: 3px solid;
      border-color: #fff #808080 #808080 #fff;
      padding: 4px 6px; display: flex; justify-content: space-between;
      align-items: center; margin-bottom: 6px;
    }
    .ms-counter {
      background: #000; color: #ff0000;
      font-family: 'Courier New', monospace; font-size: 20px;
      padding: 2px 4px; letter-spacing: 2px; min-width: 46px; text-align: right;
    }
    .ms-face-btn {
      width: 28px; height: 28px; background: #c0c0c0; border: 3px solid;
      border-color: #fff #808080 #808080 #fff;
      cursor: pointer; font-size: 16px; display: flex; align-items: center; justify-content: center;
    }
    .ms-face-btn:active { border-color: #808080 #fff #fff #808080; }
    .ms-grid { display: inline-grid; border: 3px solid; border-color: #808080 #fff #fff #808080; }
    .ms-cell {
      width: 22px; height: 22px; background: #c0c0c0; border: 2px solid;
      border-color: #fff #808080 #808080 #fff;
      display: flex; align-items: center; justify-content: center;
      font-size: 12px; font-weight: bold; cursor: pointer;
    }
    .ms-cell.revealed { border: 1px solid #808080; }
    .ms-cell.mine { background: #ff0000; }
    .ms-num-1 { color: #0000ff; }
    .ms-num-2 { color: #008000; }
    .ms-num-3 { color: #ff0000; }
    .ms-num-4 { color: #000080; }
    .ms-num-5 { color: #800000; }
    .ms-num-6 { color: #008080; }
    .ms-num-7 { color: #000000; }
    .ms-num-8 { color: #808080; }

    /* AIM */
    .aim-app { background: #fff; font-family: Arial, sans-serif; font-size: 11px; }
    .aim-header {
      background: linear-gradient(to bottom, #4488dd, #2266bb);
      padding: 6px 8px; display: flex; align-items: center; gap: 8px;
    }
    .aim-logo { font-size: 18px; }
    .aim-header-text { color: white; font-weight: bold; font-size: 12px; }
    .aim-online-bar { background: #e8f0ff; padding: 5px 8px; border-bottom: 1px solid #c0d0e8; }
    .aim-screen-name { font-weight: bold; color: #2244aa; font-size: 13px; }
    .aim-online-sub { color: #666; font-size: 9px; }
    .aim-away-msg {
      background: #ffffd0; border: 1px solid #d0d090;
      margin: 6px; padding: 6px 8px; font-size: 11px; font-style: italic; color: #444;
    }
    .aim-away-label { font-size: 9px; color: #888; font-style: normal; font-weight: bold; margin-bottom: 3px; }
    .aim-group-header {
      background: #d0d8f0; padding: 3px 8px;
      font-weight: bold; font-size: 10px; color: #2244aa;
      cursor: pointer; display: flex; justify-content: space-between;
    }
    .aim-buddy { padding: 3px 16px; display: flex; align-items: center; gap: 6px; cursor: pointer; }
    .aim-buddy:hover { background: #e8f0ff; }
    .aim-buddy-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
    .aim-buddy-dot.online { background: #00aa00; }
    .aim-buddy-dot.away { background: #ffaa00; }
    .aim-buddy-dot.offline { background: #aaa; }

    /* DIABLO II */
    .diablo-app { background: #080400; color: #c8a060; font-family: 'Times New Roman', serif; padding: 10px; }
    .diablo-title {
      color: #cc2200; font-size: 18px; font-weight: bold;
      text-align: center; text-shadow: 0 0 12px rgba(200,34,0,0.9);
      margin-bottom: 2px; letter-spacing: 4px;
    }
    .diablo-subtitle { color: #666650; font-size: 9px; text-align: center; margin-bottom: 12px; letter-spacing: 3px; }
    .diablo-char { display: flex; gap: 10px; }
    .diablo-portrait {
      width: 80px; height: 100px; background: #100600;
      border: 2px solid #4a2800;
      display: flex; align-items: center; justify-content: center;
      font-size: 50px; flex-shrink: 0;
    }
    .diablo-info { flex: 1; }
    .diablo-name { color: #e8d090; font-size: 15px; font-weight: bold; margin-bottom: 1px; }
    .diablo-class { color: #7a6040; font-size: 9px; margin-bottom: 8px; letter-spacing: 2px; }
    .diablo-stat {
      display: flex; justify-content: space-between;
      padding: 2px 0; font-size: 11px; border-bottom: 1px solid #201000;
    }
    .diablo-stat-label { color: #9a7850; }
    .diablo-stat-value { color: #e8c080; font-weight: bold; }
    .diablo-skills { margin-top: 10px; }
    .diablo-skills-title { color: #cc2200; font-size: 10px; margin-bottom: 6px; letter-spacing: 2px; text-shadow: 0 0 6px rgba(200,34,0,0.6); }
    .diablo-skill { display: flex; align-items: center; gap: 6px; padding: 2px 0; font-size: 10px; }
    .diablo-skill-name { color: #b09060; flex: 1; }
    .diablo-skill-bar { width: 80px; height: 8px; background: #150800; border: 1px solid #4a2000; border-radius: 2px; overflow: hidden; }
    .diablo-skill-fill { height: 100%; background: linear-gradient(to right, #aa1a00, #ff4400); }
    .diablo-skill-level { color: #c8a060; min-width: 18px; text-align: right; }

    /* FRUITYLOOPS */
    .fl-app { background: #252525; color: #ccc; font-family: Arial, sans-serif; font-size: 10px; padding: 8px; }
    .fl-toolbar {
      display: flex; align-items: center; gap: 5px;
      margin-bottom: 8px; padding-bottom: 6px; border-bottom: 1px solid #3a3a3a;
    }
    .fl-toolbar-btn {
      background: #383838; border: 1px solid #555; color: #ccc;
      padding: 3px 8px; font-size: 10px; cursor: pointer; border-radius: 2px;
    }
    .fl-toolbar-btn:hover { background: #454545; }
    .fl-toolbar-btn.playing { background: #1a5a1a; color: #00ff00; border-color: #00aa00; }
    .fl-bpm { color: #777; font-size: 10px; }
    .fl-bpm-value { color: #00cc00; font-weight: bold; }
    .fl-step-header { display: grid; grid-template-columns: 64px repeat(16, 1fr); gap: 1px; margin-bottom: 2px; }
    .fl-step-num { text-align: center; color: #555; font-size: 8px; padding: 1px 0; }
    .fl-step-num.beat { color: #777; font-weight: bold; }
    .fl-track { display: grid; grid-template-columns: 64px repeat(16, 1fr); gap: 1px; margin-bottom: 2px; }
    .fl-track-name {
      background: #1a1a1a; border: 1px solid #3a3a3a;
      padding: 3px 5px; font-size: 9px; color: #aaa;
      display: flex; align-items: center; border-radius: 2px;
    }
    .fl-pad {
      height: 20px; background: #1a1a1a; border: 1px solid #2a2a2a;
      cursor: pointer; border-radius: 2px;
    }
    .fl-pad:hover { background: #282828; }
    .fl-pad.active.kick    { background: #6a2000; border-color: #ff5500; box-shadow: 0 0 4px rgba(255,85,0,0.4); }
    .fl-pad.active.snare   { background: #6a5800; border-color: #ffcc00; box-shadow: 0 0 4px rgba(255,200,0,0.4); }
    .fl-pad.active.hihat   { background: #103870; border-color: #3388ff; box-shadow: 0 0 4px rgba(51,136,255,0.4); }
    .fl-pad.active.bass    { background: #3a1060; border-color: #aa44ff; box-shadow: 0 0 4px rgba(170,68,255,0.4); }
    .fl-pad.current { filter: brightness(1.6); }
  </style>
</head>
<body>

<!-- Desktop -->
<div id="desktop">
  <div class="desktop-icons">
    <div class="desktop-icon" ondblclick="openWindow('winamp')">
      <div class="icon-img">🎵</div>
      <div class="icon-label">Winamp 2.95</div>
    </div>
    <div class="desktop-icon" ondblclick="openWindow('mtg')">
      <div class="icon-img">🃏</div>
      <div class="icon-label">MTG Collection</div>
    </div>
    <div class="desktop-icon" ondblclick="openWindow('minesweeper')">
      <div class="icon-img">💣</div>
      <div class="icon-label">Minesweeper</div>
    </div>
    <div class="desktop-icon" ondblclick="openWindow('aim')">
      <div class="icon-img">💬</div>
      <div class="icon-label">AIM 5.9</div>
    </div>
    <div class="desktop-icon" ondblclick="openWindow('diablo')">
      <div class="icon-img">⚔️</div>
      <div class="icon-label">Diablo II</div>
    </div>
    <div class="desktop-icon" ondblclick="openWindow('fl')">
      <div class="icon-img">🎹</div>
      <div class="icon-label">FruityLoops 3.4</div>
    </div>
    <div class="desktop-icon" ondblclick="window.location.href='/'">
      <div class="icon-img">🌐</div>
      <div class="icon-label">jessevaughan.com</div>
    </div>
  </div>
</div>

<!-- ══ WINDOWS ══ -->

<!-- WINAMP -->
<div class="window" id="win-winamp" style="top:80px;left:60px;width:300px;">
  <div class="window-titlebar" onmousedown="startDrag(event,'win-winamp')">
    <span>🎵</span><span class="window-title-text">Winamp 2.95</span>
    <div class="window-controls">
      <div class="win-btn minimize" onclick="minimizeWindow('win-winamp')">_</div>
      <div class="win-btn maximize">□</div>
      <div class="win-btn close" onclick="closeWindow('win-winamp')">✕</div>
    </div>
  </div>
  <div class="window-body winamp">
    <div class="winamp-display">
      <div class="winamp-track" id="winamp-track">▶ Boards of Canada - Aquarius</div>
      <div style="display:flex;justify-content:space-between;align-items:center;">
        <div class="winamp-time" id="winamp-time">2:14</div>
        <div class="winamp-viz" id="winamp-viz"></div>
      </div>
    </div>
    <div class="winamp-controls">
      <button class="winamp-btn" onclick="winampPrev()">⏮</button>
      <button class="winamp-btn" id="winamp-play-btn" onclick="winampPlayPause()">⏸</button>
      <button class="winamp-btn" onclick="winampNext()">⏭</button>
      <button class="winamp-btn">⏹</button>
      <div class="winamp-volume"><div class="winamp-vol-fill"></div></div>
    </div>
    <div class="winamp-playlist">
      <div class="winamp-playlist-item active" data-idx="0"><span class="winamp-track-num">01</span>Boards of Canada - Aquarius</div>
      <div class="winamp-playlist-item" data-idx="1"><span class="winamp-track-num">02</span>Daft Punk - Digital Love</div>
      <div class="winamp-playlist-item" data-idx="2"><span class="winamp-track-num">03</span>Aphex Twin - Xtal</div>
      <div class="winamp-playlist-item" data-idx="3"><span class="winamp-track-num">04</span>Portishead - Sour Times</div>
