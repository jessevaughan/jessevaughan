---
const name = "Jesse Venticinque";
const role = "Design Engineer";
const status = "New work coming soon.";
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{name}</title>
  <meta name="description" content={`${name} — ${role}`} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=DM+Mono:wght@300;400&display=swap" rel="stylesheet" />

  <style>
    *, *::before, *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    :root {
      --ink: #0f0f0e;
      --paper: #f5f2ec;
      --accent: #c8441a;
      --muted: #8a8680;
      --serif: 'Instrument Serif', Georgia, serif;
      --mono: 'DM Mono', 'Courier New', monospace;
    }

    html, body {
      height: 100%;
    }

    body {
      background: var(--paper);
      color: var(--ink);
      font-family: var(--mono);
      font-weight: 300;
      display: grid;
      grid-template-rows: 1fr auto;
      min-height: 100vh;
      padding: clamp(1.5rem, 5vw, 3.5rem);
      position: relative;
      overflow: hidden;
    }

    /* Grain texture overlay */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
      pointer-events: none;
      z-index: 100;
      opacity: 0.6;
    }

    /* Decorative rule */
    body::after {
      content: '';
      position: fixed;
      top: 0;
      left: clamp(1.5rem, 5vw, 3.5rem);
      right: clamp(1.5rem, 5vw, 3.5rem);
      height: 1px;
      background: var(--ink);
      opacity: 0.15;
    }

    main {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding-top: 4rem;
      animation: fadeUp 0.9s cubic-bezier(0.16, 1, 0.3, 1) both;
    }

    .eyebrow {
      font-family: var(--mono);
      font-size: clamp(0.65rem, 1.2vw, 0.75rem);
      font-weight: 400;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 1.25rem;
    }

    h1 {
      font-family: var(--serif);
      font-size: clamp(3.5rem, 10vw, 8.5rem);
      line-height: 0.95;
      letter-spacing: -0.02em;
      font-weight: 400;
      max-width: 12ch;
    }

    h1 em {
      font-style: italic;
      color: var(--accent);
    }

    .descriptor {
      margin-top: 2.5rem;
      display: flex;
      align-items: baseline;
      gap: 1rem;
    }

    .descriptor::before {
      content: '';
      display: block;
      width: 2rem;
      height: 1px;
      background: var(--ink);
      flex-shrink: 0;
      position: relative;
      top: -0.1em;
    }

    .descriptor p {
      font-size: clamp(0.8rem, 1.5vw, 0.95rem);
      color: var(--muted);
      line-height: 1.6;
      max-width: 38ch;
    }

    .status-line {
      margin-top: 4rem;
      display: flex;
      align-items: center;
      gap: 0.6rem;
    }

    .dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--accent);
      animation: pulse 2.4s ease-in-out infinite;
      flex-shrink: 0;
    }

    .status-line span {
      font-size: 0.75rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--muted);
    }

    footer {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      padding-top: 2rem;
      border-top: 1px solid rgba(15,15,14,0.12);
      animation: fadeUp 1.1s cubic-bezier(0.16, 1, 0.3, 1) 0.15s both;
    }

    .contact a {
      font-size: 0.8rem;
      letter-spacing: 0.08em;
      color: var(--ink);
      text-decoration: none;
      border-bottom: 1px solid transparent;
      transition: border-color 0.2s ease, color 0.2s ease;
    }

    .contact a:hover {
      color: var(--accent);
      border-color: var(--accent);
    }

    .contact {
      display: flex;
      gap: 2rem;
    }

    .year {
      font-size: 0.75rem;
      color: var(--muted);
      letter-spacing: 0.05em;
    }

    @keyframes fadeUp {
      from {
        opacity: 0;
        transform: translateY(16px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes pulse {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.4; transform: scale(0.85); }
    }

    @media (max-width: 600px) {
      footer {
        flex-direction: column;
        align-items: flex-start;
        gap: 1rem;
      }
    }
  </style>
</head>
<body>
  <main>
    <p class="eyebrow">Portfolio</p>
    <h1>Design <em>&</em> Engineering</h1>
    <div class="descriptor">
      <p>Brand, web, and interactive work at the intersection of design systems and frontend development.</p>
    </div>
    <div class="status-line">
      <div class="dot"></div>
      <span>{status}</span>
    </div>
  </main>

  <footer>
    <nav class="contact">
      <a href="mailto:hello@yourdomain.com">Email</a>
      <a href="https://linkedin.com/in/yourhandle" target="_blank" rel="noopener">LinkedIn</a>
    </nav>
    <span class="year">© {new Date().getFullYear()}</span>
  </footer>
</body>
</html>
