---
import Base from '../layouts/Base.astro';
---
<Base title="Jesse Vaughan">
  <main>
    <div class="identity">
      <img class="avatar" src="/avatar.svg" alt="Jesse Vaughan" />
      <p class="eyebrow">Jesse Vaughan</p>
    </div>
    <h1>Design <em>&</em> Engineering</h1>
    <div class="descriptor">
      <p>Brand, web, and interactive work at the intersection of design systems and frontend development.</p>
    </div>
    <div class="status-line">
      <div class="dot"></div>
      <span>New work coming soon.</span>
    </div>
    <div class="disciplines" aria-hidden="true">
      <span>Brand</span>
      <span>Direction</span>
      <span>Web</span>
      <span>Campaigns</span>
      <span>Storytelling</span>
    </div>
  </main>

  <footer>
    <nav class="contact">
      <a href="mailto:jesse.s.vaughan@gmail.com">Email</a>
      <a href="https://www.linkedin.com/in/jessesvaughan/" target="_blank" rel="noopener">LinkedIn</a>
    </nav>
    <span class="year">© 2026</span>
  </footer>
</Base>